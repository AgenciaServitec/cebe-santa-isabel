---
import { Image } from "astro:assets";

import ButtonLink from "./ButtonLink.astro";
import SocialNetworkIcon from "./SocialNetworkIcon.astro";
import ContentWidth from "./ContentWidth.astro";
---

<footer class="text-base-dark border-t-2 border-primary pt-10">
  <ContentWidth>
    <div class="flex flex-col gap-4">
      <div
        class="flex flex-col lg:flex-row justify-between items-center gap-4 lg:text-lg"
      >
        <Image
          src="/logo.png"
          alt="Logo del colegio CEBE Santa Isabel"
          width="100"
          height="100"
          class="w-15"
        />
        <nav>
          <ul class="flex items-center gap-12">
            <li>
              <a href="/nosotros">Nosotros</a>
            </li>
            <li>
              <a href="/education">Educación</a>
            </li>
            <li>
              <a href="/education">Educación</a>
            </li>
          </ul>
        </nav>
        <ButtonLink link="/">Contáctanos</ButtonLink>
      </div>
      <div
        class="flex flex-col justify-between items-center gap-4 text-xs lg:text-sm"
      >
        <span class="order-2 text-center"
          >&copy; 2025 CEBE Santa Isabel - Diseñado con ❤️ por Agencia Servitec</span
        >
        <div class="flex gap-8">
          <SocialNetworkIcon link="/" iconName="facebook" />
          <SocialNetworkIcon link="/" iconName="instagram" />
          <SocialNetworkIcon link="/" iconName="x" />
        </div>
      </div>
    </div>
  </ContentWidth>
</footer>

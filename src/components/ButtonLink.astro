---
interface Props {
  link: string;
  light?: boolean;
}

const { link = "/", light = false } = Astro.props;
---

<a
  href={link}
  class:list={[
    "font-poppins lg:text-lg px-4 py-2 lg:px-12 lg:py-4 rounded-2xl duration-300",
    {
      "bg-white hover:bg-secondary text-secondary hover:text-white border-2 border-secondary":
        light,
      "bg-accent hover:bg-accent/90 text-white border-2 border-accent hover:border-accent/90 rounded-br-none":
        !light,
    },
  ]}
>
  <slot />
</a>
